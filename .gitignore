# Node / environment
node_modules/

# Environment files (never commit secrets)
.env
.env.local
.env.development
.env.production
.env.*
!.env.example

# Build / output
dist/
build/
coverage/

# Hosting platforms / deployment artifacts
.vercel/
.render/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Secrets, TLS keys and certificates
*.pem
*.key
*.crt
*.p12
*.pfx

# Misc - local-only config or generated files
*.local
.tmpcfg/

# Ignore common secret-like filenames
*secret*
*secrets*
*credentials*
*serviceAccount*

# Keep application source code tracked; this file only excludes generated, secret, and local files
