# Copy this file to `.env` and fill in real values before running or deploying.

PORT=
HOST=
NODE_ENV=

# Comma-separated allowed frontend origins.
FRONTEND_URL=

MONGO_URI=
JWT_SECRET=

BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=

OTP_EXPIRY_MINUTES=
OTP_RATE_LIMIT_SECONDS=
OTP_MAX_ATTEMPTS=

ADMIN_EMAIL=
ADMIN_PASSWORD=

# Legacy variables kept for compatibility if any local tooling still expects them.
EMAIL_USER=
EMAIL_PASS=

CPX_APP_ID=33896
CPX_APP_SECRET=
CPX_POSTBACK_SECRET=

# Isapay recharge integration
ISAPAY_BASE_URL=
ISAPAY_CLIENT_ID=
ISAPAY_SECRET_KEY=
ISAPAY_AUTH_MODE=basic
ISAPAY_LOOKUP_PATHS=/recharge/lookup,/lookup,/recharge/detect
ISAPAY_PLANS_PATHS=/recharge/plans,/plans
ISAPAY_CHECKOUT_PATHS=/recharge/checkout,/checkout
ISAPAY_PAY_PATHS=/recharge/pay,/pay
